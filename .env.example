# ── StockPulse Pro 環境設定 ──────────────────────
# 複製此檔為 .env 並填入您的 API 金鑰

# 伺服器設定
PORT=3000
NODE_ENV=production

# FinMind API Token（台股三大法人、資券、大戶、K線）
# 申請：https://finmindtrade.com
FINMIND_TOKEN=

# TWSE 公開資料（免 Key，直接使用）
TWSE_BASE=https://openapi.twse.com.tw/v1

# Yahoo Finance（美股報價，部署後可直接用）
YAHOO_BASE=https://query1.finance.yahoo.com/v8/finance

# 快取設定（秒）
CACHE_PRICE_TTL=30
CACHE_INSTITUTION_TTL=300
CACHE_MARGIN_TTL=300
CACHE_HOLDING_TTL=600

# CORS 允許來源（* = 全部，或指定 https://yourdomain.com）
CORS_ORIGIN=*
